# Neon Postgres connection string (from Vercel Marketplace Neon integration,
# or from the Neon console for local development)
DATABASE_URL=

# Random secret used to sign/verify JWTs. Generate with: openssl rand -hex 32
# Changing this invalidates all previously issued tokens (logs everyone out).
JWT_SECRET=

# Only needed locally when running `npm run seed`. Never commit real values.
SEED_OTAVIO_EMAIL=
SEED_OTAVIO_PASSWORD=
SEED_WIFE_EMAIL=
SEED_WIFE_NAME=
SEED_WIFE_PASSWORD=

# Vercel Blob token, only needed here if the backend cleans up photos on delete.
BLOB_READ_WRITE_TOKEN=
